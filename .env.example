# ============================================
# Personal Financial Intelligence Engine
# Environment Configuration
# ============================================

# --- Database ---
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=finance_secret_change_me
POSTGRES_DB=finance_engine
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Groq LLM ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama3-8b-8192

# --- Market Data ---
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# --- AWS (Production) ---
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=finance-engine-docs

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
