# ── Environment Variables ──
# Copy to .env and fill in actual values. NEVER commit .env to git.

# PostgreSQL
POSTGRES_USER=finengine
POSTGRES_PASSWORD=change_this_in_production
POSTGRES_DB=finengine

# Backend
DATABASE_URL=postgresql://finengine:change_this_in_production@localhost:5432/finengine
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=generate-a-secure-random-key-here
ENVIRONMENT=development

# Groq API (LLM)
GROQ_API_KEY=your_groq_api_key_here

# Market Data (optional)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# MLflow (optional)
MLFLOW_TRACKING_URI=http://localhost:5000

# AWS (production only)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=finengine-storage-production

# Observability
GRAFANA_USER=admin
GRAFANA_PASSWORD=finengine

# Rate Limiting
RATE_LIMIT_DECISIONS=20
RATE_LIMIT_WINDOW_MINUTES=1
